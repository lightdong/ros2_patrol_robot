<?xml version="1.0"?>
<robot name="first_robot">
    <!-- 机器人身体部分 -->
    <link name="base_link">
        <!-- 部件的外观描述 -->
        <visual>
            <!-- 沿着自己几何中心的偏移 和旋转量 -->
            <origin rpy="0 0 0" xyz="0 0 0"/>
            <!-- 几何形状 -->
            <geometry>
                <!-- 圆柱体 radius 半径 0.10m 高度 length 0.12m -->
                <cylinder radius="0.10" length="0.12"/>
            </geometry>
            <!-- 材质颜色 -->
            <material name="white">
                <color rgba="1 1 1 0.5"/>
            </material>
        </visual>
    </link>

    <!-- IMU惯性测量单元 -->
    <link name="imu_link">
    <!-- 部件的外观描述 -->
        <visual>
            <!-- 沿着自己几何中心的偏移 和旋转量 -->
            <origin rpy="0 0 0" xyz="0 0 0"/>
            <!-- 几何形状 -->
            <geometry>
                <!-- 长方体 长宽高者为2cm -->
                <box size="0.02 0.02 0.02"/>
            </geometry>
            <!-- 材质颜色 -->
            <material name="black">
                <color rgba="0 0 0 0.5"/>
            </material>
        </visual>
    </link>

    <!-- 机器人的关节，用于组合机器人的部件 -->
    <joint name="imu_joint" type="fixed"> 
        <parent link="base_link"/>
        <child link="imu_link"/>
        <origin xyz="0.0 0.0 0.03" rpy="0.0 0.0 0.0"/>
    </joint>
</robot>
